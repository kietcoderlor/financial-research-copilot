# Copy to .env and fill in secrets locally. Never commit .env.

# App
APP_ENV=development
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL)
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/copilot

# Redis (query + embedding cache in later phases)
REDIS_URL=redis://localhost:6379

# AWS / local ElasticMQ
AWS_REGION=us-east-1
# Local ElasticMQ (docker compose): use host elasticmq from inside containers, localhost from host
SQS_QUEUE_URL=http://localhost:9324/000000000000/ingestion-queue
# Optional; scripts/check_corpus.py can derive from SQS_QUEUE_URL (ingestion-queue → ingestion-dlq)
# SQS_DLQ_URL=http://localhost:9324/000000000000/ingestion-dlq
SQS_ENDPOINT_URL=http://localhost:9324
S3_BUCKET=financial-copilot-raw-docs

# AI APIs (optional until Phase 2+)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
