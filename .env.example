# Copy to .env and fill in secrets locally. Never commit .env.

# App
APP_ENV=development
LOG_LEVEL=INFO

# Database (async SQLAlchemy URL)
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/copilot

# Redis (query + embedding + route classification cache)
REDIS_URL=redis://localhost:6379
QUERY_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# AWS / local MinIO + ElasticMQ
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
SQS_QUEUE_URL=http://localhost:9324/000000000000/ingestion-queue
SQS_ENDPOINT_URL=http://localhost:9324
S3_BUCKET=financial-copilot-raw-docs
# MinIO S3-compatible endpoint (host machine; containers use http://minio:9000 in compose)
S3_ENDPOINT_URL=http://localhost:9000

# AI APIs — required for embeddings, LLM answers, and Cohere rerank
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
LLM_MODEL_FAST=claude-3-5-haiku-20241022
LLM_MODEL_STRONG=claude-sonnet-4-5
LLM_ROUTE_CONTEXT_CHARS=7000

# SEC EDGAR (bulk_ingest_sp500.py production mode only)
SEC_EDGAR_COMPANY_NAME=FinancialResearchCopilot
SEC_EDGAR_CONTACT_EMAIL=you@example.com

# Auth (JWT + Google + email OTP)
JWT_SECRET=dev-change-me-in-production-use-long-random-string
JWT_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
AUTH_OTP_TTL_SECONDS=600
AUTH_OTP_RATE_LIMIT_PER_HOUR=5
# Expose OTP in API response for local dev (disable in production)
AUTH_OTP_DEV_EXPOSE=true
# Require JWT on /query and /query/stream (set false for eval scripts)
QUERY_AUTH_REQUIRED=true

# Rate limits (per minute) for expensive endpoints
QUERY_RATE_LIMIT_PER_MINUTE=30
NOTES_RATE_LIMIT_PER_MINUTE=30

# SMTP for email OTP (optional in dev when AUTH_OTP_DEV_EXPOSE=true)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
